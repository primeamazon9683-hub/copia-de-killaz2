<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Site Blocked</title>
	<style>
		* { margin: 0; padding: 0; box-sizing: border-box; }
		body {
			font-family: 'SF Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
			background: #fff;
			min-height: 100vh;
			display: flex;
			flex-direction: column;
		}
		.header {
			display: flex;
			align-items: center;
			padding: 10px 20px;
			height: 60px;
		}
		.logo { cursor: pointer; }
		.logo:hover { opacity: 0.8; }
		.content {
			flex: 1;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			padding: 40px 20px;
		}
		.main-section {
			display: flex;
			flex-direction: column;
			align-items: center;
			max-width: 410px;
			width: 100%;
			gap: 40px;
		}
		.text-section {
			display: flex;
			flex-direction: column;
			align-items: center;
			width: 100%;
			gap: 4px;
		}
		.text-section h1 {
			font-size: 18px;
			font-weight: 600;
			color: #34322D;
			line-height: 24px;
			letter-spacing: -0.45px;
			text-align: center;
		}
		.subtitle-row {
			display: flex;
			align-items: center;
			gap: 4px;
		}
		.subtitle-row span {
			font-size: 13px;
			font-weight: 400;
			color: #858481;
			line-height: 18px;
			letter-spacing: -0.091px;
		}
		.subtitle-row a {
			font-size: 13px;
			font-weight: 400;
			color: #5E5E5B;
			line-height: 18px;
			letter-spacing: -0.091px;
			text-decoration: underline;
			text-underline-offset: 2px;
		}
		.subtitle-row a:hover { color: #34322D; }
		.card {
			display: flex;
			flex-direction: column;
			gap: 12px;
			padding: 12px;
			border: 1px solid rgba(0, 0, 0, 0.08);
			border-radius: 12px;
			width: 100%;
		}
		.card-text {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 4px;
		}
		.card-text h2 {
			font-size: 14px;
			font-weight: 500;
			color: #34322D;
			line-height: 20px;
			letter-spacing: -0.154px;
			text-align: center;
		}
		.card-text p {
			font-size: 13px;
			font-weight: 400;
			color: #858481;
			line-height: 18px;
			letter-spacing: -0.091px;
			text-align: center;
		}
		.card-action {
			display: flex;
			justify-content: center;
		}
		.contact-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 6px 10px;
			background: #1A1A19;
			color: #fff;
			border: none;
			border-radius: 8px;
			font-family: inherit;
			font-size: 14px;
			font-weight: 500;
			line-height: 20px;
			letter-spacing: -0.154px;
			cursor: pointer;
			text-decoration: none;
			transition: background-color 0.2s;
		}
		.contact-btn:hover { background: #2a2a29; }
	</style>
</head>
<body>
	<header class="header">
		<a class="logo" href="https://manus.im">
			<svg width="110" height="32" viewBox="0 0 110 32" fill="none" xmlns="http://www.w3.org/2000/svg">
